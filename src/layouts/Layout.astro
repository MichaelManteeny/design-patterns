---
import '../styles/global.css';
import '../styles/theme.css';
import { darkThemeClass, lightThemeClass } from '../styles/theme.css';
import Sidebar from '../components/Sidebar/Sidebar.astro';
import ThemeToggle from '../components/ThemeToggle/ThemeToggle.tsx';

interface Props {
  title: string;
  description?: string;
  currentSlug?: string;
}

const {
  title,
  description = 'Интерактивный учебник по шаблонам проектирования',
  currentSlug,
} = Astro.props;
---

<!doctype html>
<html lang="ru" class={darkThemeClass}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline define:vars={{ darkThemeClass, lightThemeClass }}>
      (function () {
        try {
          var stored = window.localStorage.getItem('theme');
          var theme = stored === 'light' || stored === 'dark' ? stored : 'dark';
          var cls = theme === 'light' ? lightThemeClass : darkThemeClass;
          var root = document.documentElement;
          root.classList.remove(darkThemeClass, lightThemeClass);
          root.classList.add(cls);
        } catch (e) {
          var root = document.documentElement;
          root.classList.remove(lightThemeClass);
          root.classList.add(darkThemeClass);
        }
      })();
    </script>
  </head>
  <body>
    <div class="app">
      <Sidebar currentSlug={currentSlug} />
      <div class="main">
        <header class="header">
          <ThemeToggle client:load />
        </header>
        <main>
          <slot />
        </main>
      </div>
    </div>

    <style is:global>
      .app {
        display: flex;
        align-items: flex-start;
        min-height: 100vh;
      }

      .main {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
      }

      .header {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: var(--spacing-spacing3);
        padding: var(--spacing-spacing3) var(--spacing-spacing5);
        border-bottom: 1px solid var(--color-border);
        background: var(--color-surfaceBgAlt);
        position: sticky;
        top: 0;
        z-index: 10;
        backdrop-filter: blur(8px);
      }

      @media (max-width: 768px) {
        .header {
          padding: var(--spacing-spacing2) var(--spacing-spacing3);
        }
      }
    </style>
  </body>
</html>
