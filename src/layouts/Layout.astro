---
import '../styles/tokens.css';
import '../styles/base.css';
import Sidebar from '../components/Sidebar/Sidebar.astro';
import ThemeToggle from '../components/ThemeToggle/ThemeToggle.tsx';

interface Props {
  title: string;
  description?: string;
  currentSlug?: string;
}

const {
  title,
  description = 'Интерактивный учебник по шаблонам проектирования',
  currentSlug,
} = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#0b0d10" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Font preconnects -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!--
      Inter (body) + Inter Tight (display) + JetBrains Mono (code).
      Includes Cyrillic + Latin subsets. Swap to system fallback if offline.
    -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Inter+Tight:wght@600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
    />

    <!-- No-flash theme bootstrap: read stored preference BEFORE first paint. -->
    <script is:inline>
      (function () {
        try {
          var stored = window.localStorage.getItem('theme');
          var theme = stored === 'light' || stored === 'dark' ? stored : 'dark';
          var root = document.documentElement;
          if (theme === 'light') {
            root.classList.add('light');
          } else {
            root.classList.remove('light');
          }
        } catch (e) {
          /* ignore */
        }
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Перейти к содержимому</a>

    <div class="shell">
      <Sidebar currentSlug={currentSlug} />

      <div class="main-column">
        <header class="topbar">
          <button
            class="menu-trigger"
            type="button"
            aria-label="Открыть навигацию"
            aria-controls="primary-nav"
            data-menu-trigger
          >
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path
                d="M4 7h16M4 12h16M4 17h16"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
              />
            </svg>
          </button>

          <a class="topbar-brand" href="/design-patterns/" aria-label="На главную">
            <span class="topbar-brand-mark" aria-hidden="true">П</span>
            <span class="topbar-brand-text">Паттерны</span>
          </a>

          <div class="topbar-actions">
            <ThemeToggle client:load />
          </div>
        </header>

        <main id="main" class="page">
          <slot />
        </main>

        <footer class="footer">
          <div class="footer-inner">
            <span class="footer-mark">П</span>
            <span>Интерактивный учебник по шаблонам проектирования</span>
          </div>
        </footer>
      </div>
    </div>

    <div class="scrim" data-menu-scrim aria-hidden="true"></div>

    <script>
      // Tiny menu drawer controller — toggles `data-menu-open` on <html>.
      // Style rules key off this attribute, so no extra React state needed.
      const triggers = document.querySelectorAll<HTMLElement>('[data-menu-trigger]');
      const scrim = document.querySelector<HTMLElement>('[data-menu-scrim]');
      const menuCloseButtons = document.querySelectorAll<HTMLElement>('[data-menu-close]');

      function setOpen(open: boolean) {
        document.documentElement.dataset.menuOpen = open ? 'true' : 'false';
        if (scrim) scrim.dataset.menuOpen = open ? 'true' : 'false';
      }

      triggers.forEach((btn) => btn.addEventListener('click', () => setOpen(true)));
      menuCloseButtons.forEach((btn) => btn.addEventListener('click', () => setOpen(false)));
      scrim?.addEventListener('click', () => setOpen(false));

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') setOpen(false);
      });
    </script>

    <style>
      .shell {
        display: flex;
        align-items: stretch;
        min-height: 100vh;
      }

      .main-column {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
        background: var(--color-surface-bg);
        overflow-x: hidden;
      }

      .topbar {
        display: flex;
        align-items: center;
        gap: var(--spacing-2);
        height: var(--layout-header-height);
        padding: 0 var(--spacing-5);
        border-bottom: 1px solid var(--color-border);
        background: color-mix(in oklab, var(--color-surface-bg-alt) 88%, transparent);
        position: sticky;
        top: 0;
        z-index: 20;
        backdrop-filter: saturate(180%) blur(14px);
        -webkit-backdrop-filter: saturate(180%) blur(14px);
      }

      .topbar-brand {
        display: flex;
        align-items: center;
        gap: var(--spacing-2);
        color: var(--color-text-strong);
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 16px;
        letter-spacing: -0.01em;
        margin-right: auto;
      }

      .topbar-brand-mark {
        width: 30px;
        height: 30px;
        border-radius: var(--radii-sm);
        background: linear-gradient(
          135deg,
          var(--color-accent-primary),
          var(--color-accent-secondary)
        );
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #ffffff;
        font-weight: 800;
        font-size: 14px;
        box-shadow: var(--shadow-glow);
      }

      .topbar-actions {
        display: flex;
        align-items: center;
        gap: var(--spacing-2);
      }

      .menu-trigger {
        display: none;
        width: 40px;
        height: 40px;
        align-items: center;
        justify-content: center;
        background: transparent;
        border: 1px solid var(--color-border);
        border-radius: var(--radii-md);
        color: var(--color-text);
        cursor: pointer;
        transition:
          background-color var(--motion-dur) var(--motion-ease),
          border-color var(--motion-dur) var(--motion-ease),
          transform var(--motion-dur-fast) var(--motion-ease);
      }
      .menu-trigger:hover {
        background: var(--color-surface-card);
        border-color: var(--color-border-hover);
      }
      .menu-trigger:active {
        transform: scale(0.96);
      }
      .menu-trigger svg {
        width: 20px;
        height: 20px;
      }

      .scrim {
        position: fixed;
        inset: 0;
        background: var(--color-scrim);
        z-index: 40;
        opacity: 0;
        pointer-events: none;
        transition: opacity var(--motion-dur) var(--motion-ease);
      }
      html[data-menu-open='true'] .scrim {
        opacity: 1;
        pointer-events: auto;
      }

      .skip-link {
        position: absolute;
        left: var(--spacing-2);
        top: var(--spacing-2);
        padding: var(--spacing-1) var(--spacing-2);
        background: var(--color-accent-primary);
        color: #ffffff;
        border-radius: var(--radii-sm);
        font-weight: 600;
        font-size: 14px;
        transform: translateY(-150%);
        transition: transform var(--motion-dur-fast) var(--motion-ease);
        z-index: 100;
      }
      .skip-link:focus-visible {
        transform: translateY(0);
      }

      .footer {
        border-top: 1px solid var(--color-border);
        margin-top: var(--spacing-8);
        background: var(--color-surface-bg-alt);
      }
      .footer-inner {
        max-width: var(--layout-max-width);
        margin: 0 auto;
        padding: var(--spacing-5);
        display: flex;
        align-items: center;
        gap: var(--spacing-2);
        color: var(--color-text-muted);
        font-size: 14px;
      }
      .footer-mark {
        width: 24px;
        height: 24px;
        border-radius: var(--radii-xs);
        background: linear-gradient(
          135deg,
          var(--color-accent-primary),
          var(--color-accent-secondary)
        );
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #ffffff;
        font-weight: 800;
        font-size: 12px;
      }

      @media (max-width: 900px) {
        .menu-trigger {
          display: inline-flex;
          order: -1;
        }
        .topbar {
          padding: 0 var(--spacing-3);
        }
      }
    </style>
  </body>
</html>
