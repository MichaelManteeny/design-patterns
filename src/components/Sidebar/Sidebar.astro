---
import { getCollection } from 'astro:content';

interface Props {
  currentSlug?: string;
}

const { currentSlug } = Astro.props;

const allPatterns = await getCollection('patterns');
const sorted = [...allPatterns].sort(
  (a, b) => a.data.order - b.data.order,
);

const groups: { id: 'creational' | 'structural' | 'behavioral'; label: string; emoji: string }[] = [
  { id: 'creational', label: 'Порождающие', emoji: '🏭' },
  { id: 'structural', label: 'Структурные', emoji: '🧩' },
  { id: 'behavioral', label: 'Поведенческие', emoji: '🔁' },
];
---

<aside class="sidebar" id="primary-nav" aria-label="Навигация по паттернам">
  <div class="sidebar-header">
    <span class="sidebar-eyebrow">Каталог</span>
    <button
      type="button"
      class="close-btn"
      data-menu-close
      aria-label="Закрыть навигацию"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path
          d="M6 6l12 12M6 18L18 6"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        />
      </svg>
    </button>
  </div>

  <nav class="nav">
    <a
      href="/design-patterns/"
      class:list={['overview-link', { active: !currentSlug }]}
      aria-current={!currentSlug ? 'page' : undefined}
    >
      <span class="overview-icon" aria-hidden="true">⌂</span>
      <span>Все паттерны</span>
    </a>

    {groups.map((group) => {
      const items = sorted.filter((p) => p.data.category === group.id);
      if (items.length === 0) return null;
      return (
        <section class={`group group-${group.id}`}>
          <h3 class="group-title">
            <span class="group-emoji" aria-hidden="true">{group.emoji}</span>
            <span>{group.label}</span>
            <span class="group-count">{items.length}</span>
          </h3>
          <ul class="group-list">
            {items.map((pattern) => {
              const href = `/design-patterns/patterns/${pattern.slug}/`;
              const isActive = currentSlug === pattern.slug;
              return (
                <li>
                  <a
                    href={href}
                    class:list={['link', { active: isActive }]}
                    aria-current={isActive ? 'page' : undefined}
                    data-menu-close
                  >
                    <span class="link-order">{pattern.data.order}</span>
                    <span class="link-label">{pattern.data.title}</span>
                    <span class="link-arrow" aria-hidden="true">→</span>
                  </a>
                </li>
              );
            })}
          </ul>
        </section>
      );
    })}
  </nav>

  <div class="sidebar-footer">
    <span class="footer-dot" aria-hidden="true"></span>
    <span>10 паттернов</span>
  </div>
</aside>

<style>
  .sidebar {
    width: var(--layout-sidebar-width);
    flex-shrink: 0;
    height: 100vh;
    position: sticky;
    top: 0;
    overflow-y: auto;
    background: var(--color-surface-bg-alt);
    border-right: 1px solid var(--color-border);
    padding: var(--spacing-4) 0;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    z-index: 30;
  }

  .sidebar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--spacing-4);
    margin-bottom: var(--spacing-5);
  }

  .sidebar-eyebrow {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
  }

  .close-btn {
    display: none;
    width: 36px;
    height: 36px;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radii-sm);
    color: var(--color-text);
    cursor: pointer;
    margin-left: var(--spacing-2);
  }
  .close-btn:hover {
    background: var(--color-surface-card);
    border-color: var(--color-border-hover);
  }
  .close-btn svg {
    width: 18px;
    height: 18px;
  }

  .nav {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-5);
    flex: 1;
    padding: 0 var(--spacing-2);
  }

  .overview-link {
    display: flex;
    align-items: center;
    gap: var(--spacing-2);
    padding: var(--spacing-2) var(--spacing-3);
    margin: 0 var(--spacing-2);
    color: var(--color-text);
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    border-radius: var(--radii-sm);
    transition: background-color var(--motion-dur) var(--motion-ease),
      color var(--motion-dur) var(--motion-ease);
  }
  .overview-link:hover {
    background: var(--color-surface-card);
    color: var(--color-text-strong);
  }
  .overview-link.active {
    background: var(--color-surface-card);
    color: var(--color-text-strong);
  }
  .overview-icon {
    font-size: 16px;
    color: var(--color-accent-primary);
  }

  .group-title {
    margin: 0 0 var(--spacing-2);
    padding: 0 var(--spacing-3);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: var(--spacing-1);
  }
  .group-emoji {
    font-size: 13px;
    line-height: 1;
  }
  .group-count {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 22px;
    height: 20px;
    padding: 0 6px;
    border-radius: var(--radii-full);
    background: var(--color-surface-card);
    border: 1px solid var(--color-border);
    font-size: 10px;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    color: var(--color-text-muted);
  }

  .group-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .link {
    position: relative;
    display: flex;
    align-items: center;
    gap: var(--spacing-2);
    padding: var(--spacing-2) var(--spacing-3);
    color: var(--color-text);
    text-decoration: none;
    font-size: 13.5px;
    line-height: 1.3;
    font-weight: 500;
    border-radius: var(--radii-sm);
    transition: background-color var(--motion-dur) var(--motion-ease),
      color var(--motion-dur) var(--motion-ease),
      transform var(--motion-dur-fast) var(--motion-ease);
  }

  .link:hover {
    background: var(--color-surface-card);
    color: var(--color-text-strong);
  }

  .link:hover .link-arrow {
    transform: translateX(2px);
    opacity: 1;
  }

  .link.active {
    background: var(--color-surface-card);
    color: var(--color-text-strong);
    font-weight: 700;
    box-shadow: var(--shadow-xs);
  }
  .link.active::before {
    content: '';
    position: absolute;
    left: -2px;
    top: 6px;
    bottom: 6px;
    width: 3px;
    border-radius: 0 var(--radii-xs) var(--radii-xs) 0;
    background: linear-gradient(
      180deg,
      var(--color-accent-primary),
      var(--color-accent-secondary)
    );
  }

  .link-order {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 22px;
    height: 22px;
    padding: 0 6px;
    border-radius: var(--radii-xs);
    background: var(--color-surface-bg);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    font-size: 10.5px;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
    transition: all var(--motion-dur) var(--motion-ease);
  }
  .link.active .link-order {
    background: linear-gradient(
      135deg,
      var(--color-accent-primary),
      var(--color-accent-secondary)
    );
    color: #ffffff;
    border-color: transparent;
  }

  .link-label {
    flex: 1;
    min-width: 0;
  }

  .link-arrow {
    color: var(--color-accent-primary);
    opacity: 0;
    transition: all var(--motion-dur) var(--motion-ease);
    font-weight: 600;
  }

  /* Accent bar tints based on category */
  .group-creational .link.active::before {
    background: linear-gradient(180deg, #ff7849, #fb923c);
  }
  .group-structural .link.active::before {
    background: linear-gradient(180deg, #2dd4bf, #0d9488);
  }
  .group-behavioral .link.active::before {
    background: linear-gradient(180deg, #a78bfa, #7c3aed);
  }

  .sidebar-footer {
    margin-top: var(--spacing-4);
    padding: var(--spacing-3) var(--spacing-4);
    border-top: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-size: 11.5px;
    display: flex;
    align-items: center;
    gap: var(--spacing-1);
  }

  .footer-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-success);
    box-shadow: 0 0 0 3px color-mix(in oklab, var(--color-success) 30%, transparent);
  }

  /* Mobile: sidebar becomes a slide-in drawer */
  @media (max-width: 900px) {
    .sidebar {
      position: fixed;
      top: 0;
      left: 0;
      width: min(320px, 86vw);
      transform: translateX(-100%);
      transition: transform var(--motion-dur-slow) var(--motion-ease-out);
      border-right: 1px solid var(--color-border);
    }
    html[data-menu-open='true'] .sidebar {
      transform: translateX(0);
    }
    .close-btn {
      display: inline-flex;
    }
  }
</style>
