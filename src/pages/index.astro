---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const patterns = await getCollection('patterns');
const sorted = [...patterns].sort((a, b) => a.data.order - b.data.order);

const groups = [
  {
    id: 'creational',
    label: 'Порождающие',
    description: 'Создание объектов — гибкое и переиспользуемое',
    emoji: '🏭',
    accent: 'creational',
  },
  {
    id: 'structural',
    label: 'Структурные',
    description: 'Композиция классов и объектов',
    emoji: '🧩',
    accent: 'structural',
  },
  {
    id: 'behavioral',
    label: 'Поведенческие',
    description: 'Коммуникация между объектами',
    emoji: '🔁',
    accent: 'behavioral',
  },
] as const;

type Category = 'creational' | 'structural' | 'behavioral';

const categoryLabel: Record<Category, string> = {
  creational: 'Порождающий',
  structural: 'Структурный',
  behavioral: 'Поведенческий',
};
---

<Layout
  title="Паттерны проектирования — Интерактивный учебник для стажёров"
  description="Интерактивный учебник по шаблонам проектирования с живыми примерами на TypeScript и React."
>
  <section class="hero">
    <div class="hero-eyebrow">
      <span class="hero-dot" aria-hidden="true"></span>
      <span>Для стажёров и джунов</span>
    </div>
    <h1 class="hero-title">
      Паттерны <span class="hero-accent">проектирования</span>
    </h1>
    <p class="hero-subtitle">
      Интерактивный учебник по классическим шаблонам проектирования.
      Без воды — с живыми примерами на TypeScript и React, визуализациями
      и понятным русским языком.
    </p>

    <div class="hero-stats" role="list">
      <div class="stat" role="listitem">
        <span class="stat-value">10</span>
        <span class="stat-label">паттернов</span>
      </div>
      <div class="stat" role="listitem">
        <span class="stat-value">3</span>
        <span class="stat-label">категории</span>
      </div>
      <div class="stat" role="listitem">
        <span class="stat-value">TS</span>
        <span class="stat-label">+ React</span>
      </div>
      <div class="stat" role="listitem">
        <span class="stat-value">∞</span>
        <span class="stat-label">повторов</span>
      </div>
    </div>
  </section>

  <div class="section-divider" aria-hidden="true">
    <span>Каталог</span>
  </div>

  {groups.map((group) => {
    const items = sorted.filter((p) => p.data.category === group.id);
    if (items.length === 0) return null;
    return (
      <section
        class={`category-section category-${group.accent}`}
        aria-labelledby={`cat-${group.id}`}
      >
        <header class="category-header">
          <span class="category-emoji" aria-hidden="true">{group.emoji}</span>
          <div class="category-meta">
            <h2 id={`cat-${group.id}`} class="category-title">
              {group.label}
            </h2>
            <p class="category-desc">{group.description}</p>
          </div>
          <span class="category-badge" aria-label={`${items.length} паттернов`}>
            {items.length}
          </span>
        </header>

        <div class="pattern-grid">
          {items.map((pattern) => (
            <a
              class="pattern-card"
              href={`/design-patterns/patterns/${pattern.slug}/`}
              aria-label={`Открыть паттерн ${pattern.data.title}`}
              data-category={pattern.data.category}
            >
              <div class="pattern-card-top">
                <span
                  class:list={[
                    'pattern-card-tag',
                    `tag-${pattern.data.category}`,
                  ]}
                >
                  {categoryLabel[pattern.data.category]}
                </span>
                <span class="pattern-card-number">{pattern.data.order}</span>
              </div>
              <h3 class="pattern-card-title">{pattern.data.title}</h3>
              <p class="pattern-card-description">{pattern.data.description}</p>
              <span class="pattern-card-cta">
                Открыть
                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                  <path
                    d="M5 12h14M13 5l7 7-7 7"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    fill="none"
                  />
                </svg>
              </span>
            </a>
          ))}
        </div>
      </section>
    );
  })}
</Layout>

<style>
  /* ========================================================== Hero */
  .hero {
    max-width: var(--layout-max-width);
    margin: 0 auto;
    padding: var(--spacing-7) var(--spacing-5) var(--spacing-6);
    text-align: left;
    position: relative;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -10%;
    left: -10%;
    width: 60%;
    height: 80%;
    background: radial-gradient(
      circle at 30% 30%,
      color-mix(in oklab, var(--color-accent-primary) 25%, transparent) 0%,
      transparent 60%
    );
    pointer-events: none;
    filter: blur(40px);
    z-index: 0;
  }

  .hero > * {
    position: relative;
    z-index: 1;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-1);
    padding: 6px 12px;
    background: color-mix(in oklab, var(--color-accent-primary) 12%, transparent);
    border: 1px solid color-mix(in oklab, var(--color-accent-primary) 35%, transparent);
    border-radius: var(--radii-full);
    font-size: 12.5px;
    font-weight: 600;
    color: var(--color-accent-primary);
    margin-bottom: var(--spacing-4);
  }

  .hero-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent-primary);
    box-shadow: 0 0 0 3px color-mix(in oklab, var(--color-accent-primary) 30%, transparent);
  }

  .hero-title {
    margin: 0;
    font-size: clamp(40px, 7vw, 76px);
    font-weight: 800;
    line-height: 1.02;
    letter-spacing: -0.035em;
    color: var(--color-text-strong);
    max-width: 14ch;
  }

  .hero-accent {
    background: linear-gradient(
      135deg,
      var(--color-accent-primary) 0%,
      var(--color-accent-secondary) 50%,
      var(--color-accent-deep) 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .hero-subtitle {
    margin: var(--spacing-3) 0 0;
    max-width: 56ch;
    font-size: clamp(16px, 2vw, 19px);
    line-height: 1.55;
    color: var(--color-text-muted);
  }

  .hero-stats {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-3);
    margin-top: var(--spacing-5);
  }

  .stat {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    padding: var(--spacing-2) var(--spacing-4);
    border: 1px solid var(--color-border);
    background: var(--color-surface-card);
    border-radius: var(--radii-md);
    min-width: 96px;
    transition:
      border-color var(--motion-dur) var(--motion-ease),
      transform var(--motion-dur-fast) var(--motion-ease);
  }

  .stat:hover {
    border-color: var(--color-border-hover);
    transform: translateY(-1px);
  }

  .stat-value {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--color-text-strong);
    line-height: 1;
  }

  .stat-label {
    font-size: 11.5px;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
    margin-top: 4px;
  }

  /* ========================================================== Section divider */

  .section-divider {
    max-width: var(--layout-max-width);
    margin: 0 auto;
    padding: 0 var(--spacing-5);
    display: flex;
    align-items: center;
    gap: var(--spacing-3);
    color: var(--color-text-muted);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 700;
  }

  .section-divider::before,
  .section-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--color-border);
  }

  /* ========================================================== Category sections */

  .category-section {
    max-width: var(--layout-max-width);
    margin: var(--spacing-6) auto;
    padding: 0 var(--spacing-5);
  }

  .category-header {
    display: flex;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: var(--spacing-3);
    margin-bottom: var(--spacing-5);
  }

  .category-emoji {
    width: 56px;
    height: 56px;
    border-radius: var(--radii-md);
    background: var(--color-surface-card);
    border: 1px solid var(--color-border);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    flex-shrink: 0;
  }

  .category-creational .category-emoji {
    background: color-mix(in oklab, var(--color-accent-primary) 12%, var(--color-surface-card));
    border-color: color-mix(in oklab, var(--color-accent-primary) 30%, var(--color-border));
  }
  .category-structural .category-emoji {
    background: color-mix(in oklab, var(--color-accent-teal) 12%, var(--color-surface-card));
    border-color: color-mix(in oklab, var(--color-accent-teal) 30%, var(--color-border));
  }
  .category-behavioral .category-emoji {
    background: color-mix(in oklab, var(--color-accent-violet) 12%, var(--color-surface-card));
    border-color: color-mix(in oklab, var(--color-accent-violet) 30%, var(--color-border));
  }

  .category-meta {
    flex: 1;
    min-width: 0;
  }

  .category-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(20px, 2.5vw, 26px);
    font-weight: 800;
    color: var(--color-text-strong);
    letter-spacing: -0.02em;
  }

  .category-desc {
    margin: 4px 0 0;
    font-size: 14px;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .category-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 32px;
    height: 28px;
    padding: 0 10px;
    margin-left: auto;
    border-radius: var(--radii-full);
    background: var(--color-surface-card);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-size: 12px;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
    align-self: flex-start;
  }

  /* ========================================================== Card grid */

  .pattern-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(260px, 100%), 1fr));
    gap: 16px;
    padding-right: 16px;
    box-sizing: border-box;
  }

  .pattern-card {
    --card-accent: var(--color-accent-primary);
    position: relative;
    display: flex;
    flex-direction: column;
    padding: var(--spacing-4);
    background: var(--color-surface-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radii-lg);
    color: inherit;
    text-decoration: none;
    overflow: hidden;
    isolation: isolate;
    transition:
      border-color var(--motion-dur) var(--motion-ease),
      transform var(--motion-dur) var(--motion-ease-out),
      box-shadow var(--motion-dur) var(--motion-ease),
      background-color var(--motion-dur) var(--motion-ease);
  }

  .pattern-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--card-accent), transparent);
    opacity: 0;
    transition: opacity var(--motion-dur) var(--motion-ease);
    z-index: 1;
  }

  .pattern-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at top right,
      color-mix(in oklab, var(--card-accent) 12%, transparent),
      transparent 60%
    );
    opacity: 0;
    transition: opacity var(--motion-dur-slow) var(--motion-ease);
    pointer-events: none;
    z-index: 0;
  }

  .pattern-card[data-category='creational'] {
    --card-accent: var(--color-accent-primary);
  }
  .pattern-card[data-category='structural'] {
    --card-accent: var(--color-accent-teal);
  }
  .pattern-card[data-category='behavioral'] {
    --card-accent: var(--color-accent-violet);
  }

  .pattern-card:hover,
  .pattern-card:focus-visible {
    border-color: color-mix(in oklab, var(--card-accent) 40%, var(--color-border));
    background: var(--color-surface-card-hover);
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }
  .pattern-card:hover::before,
  .pattern-card:focus-visible::before,
  .pattern-card:hover::after,
  .pattern-card:focus-visible::after {
    opacity: 1;
  }
  .pattern-card:focus-visible {
    outline: 2px solid var(--color-accent-primary);
    outline-offset: 4px;
  }

  .pattern-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--spacing-3);
    position: relative;
    z-index: 2;
  }

  .pattern-card-tag {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    border-radius: var(--radii-full);
    font-size: 10.5px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    background: var(--color-surface-bg-alt);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    transition: all var(--motion-dur) var(--motion-ease);
  }
  .tag-creational {
    color: var(--color-accent-primary);
    border-color: color-mix(in oklab, var(--color-accent-primary) 40%, transparent);
    background: color-mix(in oklab, var(--color-accent-primary) 10%, transparent);
  }
  .tag-structural {
    color: var(--color-accent-teal);
    border-color: color-mix(in oklab, var(--color-accent-teal) 40%, transparent);
    background: color-mix(in oklab, var(--color-accent-teal) 10%, transparent);
  }
  .tag-behavioral {
    color: var(--color-accent-violet);
    border-color: color-mix(in oklab, var(--color-accent-violet) 40%, transparent);
    background: color-mix(in oklab, var(--color-accent-violet) 10%, transparent);
  }

  .pattern-card-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 32px;
    height: 32px;
    padding: 0 10px;
    border-radius: var(--radii-sm);
    background: var(--color-surface-bg-alt);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 800;
    font-variant-numeric: tabular-nums;
    transition: all var(--motion-dur) var(--motion-ease);
  }
  .pattern-card:hover .pattern-card-number {
    background: var(--card-accent);
    border-color: transparent;
    color: #ffffff;
  }

  .pattern-card-title {
    margin: 0 0 var(--spacing-1);
    font-family: var(--font-display);
    font-size: 19px;
    font-weight: 700;
    color: var(--color-text-strong);
    letter-spacing: -0.015em;
    line-height: 1.3;
    position: relative;
    z-index: 2;
  }

  .pattern-card-description {
    margin: 0 0 var(--spacing-4);
    font-size: 14px;
    line-height: 1.55;
    color: var(--color-text-muted);
    position: relative;
    z-index: 2;
    /* clamp to 4 lines for grid harmony */
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .pattern-card-cta {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--card-accent);
    font-size: 13px;
    font-weight: 700;
    position: relative;
    z-index: 2;
  }
  .pattern-card-cta svg {
    width: 14px;
    height: 14px;
    transition: transform var(--motion-dur) var(--motion-ease-out);
  }
  .pattern-card:hover .pattern-card-cta svg {
    transform: translateX(3px);
  }

  /* ========================================================== Mobile */

  @media (max-width: 720px) {
    .hero {
      padding: var(--spacing-5) var(--spacing-3) var(--spacing-4);
    }
    .hero-stats {
      gap: var(--spacing-2);
    }
    .stat {
      padding: var(--spacing-1) var(--spacing-3);
      min-width: 76px;
      flex: 1;
    }
    .stat-value {
      font-size: 18px;
    }
    .section-divider,
    .category-section {
      padding-left: var(--spacing-3);
      padding-right: var(--spacing-3);
    }
    .category-header {
      gap: var(--spacing-2);
    }
    .category-emoji {
      width: 48px;
      height: 48px;
      font-size: 22px;
    }
    .pattern-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-2);
    }
  }
</style>
