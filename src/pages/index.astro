---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/ThemeToggle/ThemeToggle.tsx';
import { getCollection } from 'astro:content';

const patterns = await getCollection('patterns');
const sorted = [...patterns].sort((a, b) => a.data.order - b.data.order);

const groups = [
  { id: 'creational', label: 'Порождающие', emoji: '🏭' },
  { id: 'structural', label: 'Структурные', emoji: '🧩' },
  { id: 'behavioral', label: 'Поведенческие', emoji: '🔁' },
] as const;

type Category = 'creational' | 'structural' | 'behavioral';

const categoryLabel: Record<Category, string> = {
  creational: 'Порождающий',
  structural: 'Структурный',
  behavioral: 'Поведенческий',
};
---

<Layout title="Паттерны проектирования — Интерактивный учебник для стажёров">
  <header class="site-header">
    <a href="/design-patterns/" class="brand" aria-label="На главную">
      <span class="brand-mark" aria-hidden="true">П</span>
      <span>Паттерны</span>
    </a>
    <ThemeToggle client:load />
  </header>

  <main class="main">
    <section class="hero">
      <h1 class="title">
        Паттерны <span class="title-accent">проектирования</span>
      </h1>
      <p class="subtitle">
        Интерактивный учебник для стажёров — порождающие, структурные и поведенческие шаблоны
        с живыми примерами на TypeScript и React.
      </p>
    </section>

    {groups.map((group) => {
      const items = sorted.filter((p) => p.data.category === group.id);
      if (items.length === 0) return null;
      return (
        <section class="category-section" aria-labelledby={`cat-${group.id}`}>
          <h2 id={`cat-${group.id}`} class="category-title">
            <span aria-hidden="true">{group.emoji}</span>
            <span>{group.label}</span>
            <span class="category-count">{items.length}</span>
          </h2>
          <div class="pattern-grid">
            {items.map((pattern) => (
              <a
                class="pattern-card-link"
                href={`/design-patterns/patterns/${pattern.slug}/`}
                aria-label={`Открыть паттерн ${pattern.data.title}`}
              >
                <span
                  class:list={[
                    'badge',
                    pattern.data.category === 'creational' && 'badge-creational',
                    pattern.data.category === 'structural' && 'badge-structural',
                    pattern.data.category === 'behavioral' && 'badge-behavioral',
                  ]}
                >
                  {categoryLabel[pattern.data.category]}
                </span>
                <h3 class="pattern-card-title">
                  <span class="pattern-card-order">{pattern.data.order}</span>
                  {pattern.data.title}
                </h3>
                <p class="pattern-card-description">{pattern.data.description}</p>
              </a>
            ))}
          </div>
        </section>
      );
    })}
  </main>
</Layout>

<style>
  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-spacing3);
    padding: var(--spacing-spacing3) var(--spacing-spacing5);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surfaceBgAlt);
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(8px);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: var(--spacing-spacing2);
    color: var(--color-textStrong);
    text-decoration: none;
    font-weight: 700;
    font-size: 16px;
  }

  .brand-mark {
    width: 32px;
    height: 32px;
    border-radius: var(--radii-radiiSm);
    background: linear-gradient(
      135deg,
      var(--color-accentPrimary),
      var(--color-accentSecondary)
    );
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    font-weight: 800;
    font-size: 14px;
    box-shadow: var(--shadow-shadowSm);
  }

  .main {
    max-width: 960px;
    margin: 0 auto;
    padding: var(--spacing-spacing6) var(--spacing-spacing5);
  }

  .hero {
    text-align: center;
    margin-bottom: var(--spacing-spacing6);
  }

  .title {
    margin: 0;
    font-size: clamp(32px, 6vw, 56px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-textStrong);
  }

  .title-accent {
    background: linear-gradient(
      135deg,
      var(--color-accentPrimary),
      var(--color-accentSecondary)
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: transparent;
  }

  .subtitle {
    margin: var(--spacing-spacing3) auto 0;
    font-size: clamp(16px, 2.4vw, 20px);
    color: var(--color-textMuted);
    max-width: 640px;
    line-height: 1.5;
  }

  .category-section {
    margin-top: var(--spacing-spacing6);
  }

  .category-title {
    display: flex;
    align-items: center;
    gap: var(--spacing-spacing2);
    margin: 0 0 var(--spacing-spacing3);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-textMuted);
  }

  .category-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 22px;
    height: 22px;
    padding: 0 6px;
    border-radius: var(--radii-radiiSm);
    background: var(--color-surfaceCard);
    color: var(--color-textMuted);
    font-size: 11px;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }

  .pattern-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--spacing-spacing3);
  }

  .pattern-card-link {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: var(--spacing-spacing4);
    background: var(--color-surfaceCard);
    border: 1px solid var(--color-border);
    border-radius: var(--radii-radiiLg);
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .pattern-card-link:hover {
    border-color: var(--color-accentPrimary);
    transform: translateY(-2px);
    box-shadow: var(--shadow-shadowMd);
  }

  .pattern-card-link:focus-visible {
    outline: 2px solid var(--color-accentPrimary);
    outline-offset: 2px;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-textMuted);
    background: var(--color-surfaceBgAlt);
    border: 1px solid var(--color-border);
    margin-bottom: var(--spacing-spacing2);
  }

  .badge-creational {
    color: var(--color-accentPrimary);
    border-color: var(--color-accentPrimary);
  }

  .badge-structural {
    color: var(--color-success);
    border-color: var(--color-success);
  }

  .badge-behavioral {
    color: var(--color-warning);
    border-color: var(--color-warning);
  }

  .pattern-card-title {
    display: flex;
    align-items: center;
    margin: var(--spacing-spacing1) 0 var(--spacing-spacing2);
    font-size: 18px;
    font-weight: 700;
    color: var(--color-textStrong);
  }

  .pattern-card-order {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 26px;
    height: 26px;
    padding: 0 8px;
    margin-right: var(--spacing-spacing2);
    border-radius: var(--radii-radiiSm);
    background: var(--color-surfaceBgAlt);
    color: var(--color-textMuted);
    font-size: 12px;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }

  .pattern-card-description {
    margin: 0;
    font-size: 14px;
    line-height: 1.5;
    color: var(--color-textMuted);
  }

  .site-header a:focus-visible {
    outline: 2px solid var(--color-accentPrimary);
    outline-offset: 2px;
    border-radius: var(--radii-radiiSm);
  }
</style>