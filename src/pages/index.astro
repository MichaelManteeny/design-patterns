---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/ThemeToggle/ThemeToggle.tsx';
import { getCollection } from 'astro:content';
import * as styles from '../styles/index.css';

const patterns = await getCollection('patterns');
const sorted = [...patterns].sort((a, b) => a.data.order - b.data.order);

const groups = [
  { id: 'creational', label: 'Порождающие', emoji: '🏭' },
  { id: 'structural', label: 'Структурные', emoji: '🧩' },
  { id: 'behavioral', label: 'Поведенческие', emoji: '🔁' },
] as const;

const badgeClass = (category: 'creational' | 'structural' | 'behavioral') => {
  if (category === 'creational') return `${styles.patternCardBadge} ${styles.patternCardBadgeCreational}`;
  if (category === 'structural') return `${styles.patternCardBadge} ${styles.patternCardBadgeStructural}`;
  return `${styles.patternCardBadge} ${styles.patternCardBadgeBehavioral}`;
};
---

<Layout title="Паттерны проектирования — Интерактивный учебник для стажёров">
  <header class={styles.siteHeader}>
    <a href="/design-patterns/" class={styles.brand} aria-label="На главную">
      <span class={styles.brandMark} aria-hidden="true">П</span>
      <span>Паттерны</span>
    </a>
    <ThemeToggle client:load />
  </header>

  <main class={styles.main}>
    <section class={styles.hero}>
      <h1 class={styles.title}>
        Паттерны <span class={styles.titleAccent}>проектирования</span>
      </h1>
      <p class={styles.subtitle}>
        Интерактивный учебник для стажёров — порождающие, структурные и поведенческие шаблоны
        с живыми примерами на TypeScript и React.
      </p>
    </section>

    {groups.map((group) => {
      const items = sorted.filter((p) => p.data.category === group.id);
      if (items.length === 0) return null;
      return (
        <section class={styles.categorySection} aria-labelledby={`cat-${group.id}`}>
          <h2 id={`cat-${group.id}`} class={styles.categoryTitle}>
            <span aria-hidden="true">{group.emoji}</span>
            <span>{group.label}</span>
            <span class={styles.categoryCount}>{items.length}</span>
          </h2>
          <div class={styles.patternGrid}>
            {items.map((pattern) => (
              <a
                class={styles.patternCardLink}
                href={`/design-patterns/patterns/${pattern.slug}/`}
                aria-label={`Открыть паттерн ${pattern.data.title}`}
              >
                <span class={badgeClass(pattern.data.category)}>
                  {pattern.data.category === 'creational'
                    ? 'Порождающий'
                    : pattern.data.category === 'structural'
                    ? 'Структурный'
                    : 'Поведенческий'}
                </span>
                <h3 class={styles.patternCardTitle}>
                  <span class={styles.patternCardOrder}>{pattern.data.order}</span>
                  {pattern.data.title}
                </h3>
                <p class={styles.patternCardDescription}>
                  {pattern.data.description}
                </p>
              </a>
            ))}
          </div>
        </section>
      );
    })}
  </main>
</Layout>